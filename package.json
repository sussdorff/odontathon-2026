{
  "name": "odontathon-2026",
  "version": "0.1.0",
  "description": "Dental Billing Voice Agent — Odontathon 2026",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "bun test src/lib/ src/seed/ src/agent/ src/tests/ tests/",
    "seed:catalogs": "bun run scripts/seed-catalogs.ts",
    "seed:practice": "bun run scripts/seed-practice.ts",
    "seed:past-invoices": "bun run src/seed/past-invoices.ts",
    "etl:goz": "bun run etl/goz/to_fhir.ts",
    "etl:bema": "bun run etl/bema/to_fhir.ts",
    "etl:festzuschuss": "bun run etl/festzuschuss/to_fhir.ts",
    "etl:kuerzel": "bun run etl/kuerzel/to_fhir.ts",
    "etl:punktwerte": "bun run etl/punktwerte/to_fhir.ts",
    "etl:all": "bun run etl:goz && bun run etl:bema && bun run etl:festzuschuss && bun run etl:kuerzel && bun run etl:punktwerte",
    "typecheck": "tsc --noEmit",
    "dev:fixture": "AGENT_FIXTURE_MODE=true bun run --watch src/index.ts",
    "reset:demo-data": "bun run seed:practice",
    "dev:frontend": "cd frontend && bun run dev",
    "build:frontend": "cd frontend && bun run build",
    "dev:all": "bun run dev & bun run dev:frontend"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "@anthropic-ai/sdk": "^0.78.0",
    "@xmldom/xmldom": "^0.9",
    "hono": "^4",
    "jszip": "^3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
