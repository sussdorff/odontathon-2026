{
  "name": "odontathon-2026",
  "version": "0.1.0",
  "description": "Dental Billing Voice Agent — Odontathon 2026",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "bun test",
    "seed:catalogs": "bun run scripts/seed-catalogs.ts",
    "etl:goz": "bun run etl/goz/parse.ts && bun run etl/goz/to_fhir.ts",
    "etl:bema": "bun run etl/bema/parse.ts && bun run etl/bema/to_fhir.ts",
    "typecheck": "tsc --noEmit",
    "seed:practice": "bun run scripts/seed-practice.ts"
  },
  "dependencies": {
    "hono": "^4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
